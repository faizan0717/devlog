# Server-only values for the local devLog MCP server.
# Do not expose DEVLOG_SUPABASE_SERVICE_ROLE_KEY in the Vite frontend.
DEVLOG_SUPABASE_URL=https://your-project-id.supabase.co
DEVLOG_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DEVLOG_AGENT_TOKEN=dl_agent_generated_token_here

# Hosted/HTTP MCP mode
PORT=8787
DEVLOG_MCP_ALLOWED_ORIGIN=*
