{
  "name": "@devlog/mcp-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local MCP server for owner-scoped devLog project updates.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "start": "node dist/src/http.js",
    "start:stdio": "node dist/src/index.js",
    "start:http": "node dist/src/http.js",
    "token:create": "tsx scripts/create-token.ts",
    "setup:claude-code": "tsx scripts/setup-claude-code.ts",
    "test:setup": "bash scripts/test-setup-sh.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^17.4.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.6.3"
  }
}
